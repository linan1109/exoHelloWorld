Bootstrap: docker
From: python:3.13-slim

%arguments
    VERSION=latest

%files
    pyproject.toml /app/

%post
    cd /app
    pip install --no-cache-dir uv
    uv venv /opt/venv
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"
    
    uv sync --no-install-project

%environment
    export PATH="/opt/venv/bin:$PATH"
    export VIRTUAL_ENV="/opt/venv"
    export UV_NO_SYNC=1
    export UV_FROZEN=1
    
    export EXOHW_VERSION={{ VERSION }}