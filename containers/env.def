Bootstrap: docker
From: python:3.13-slim

%arguments
    VERSION=latest

%files
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/

%post
    cd /app
    pip install --no-cache-dir uv
    
    uv venv /opt/venv
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"

    export SETUPTOOLS_SCM_PRETEND_VERSION={{ VERSION }}
    export HATCH_BUILD_SET_CANONICAL_VERSION={{ VERSION }}

    uv sync --no-install-project --active

%environment
    export PATH="/opt/venv/bin:$PATH"
    export VIRTUAL_ENV="/opt/venv"
    export UV_NO_SYNC=1
    export UV_FROZEN=1
    
    export EXOHW_VERSION={{ VERSION }}